{
	"name": "wsr-flash-card",
	"version": "4.2.0",
	"description": "A flashcard learning plugin for Obsidian based on FSRS algorithm",
	"keywords": [],
	"license": "0-BSD",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --watch --mode development",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"build": "npm run typecheck && vite build",
		"deploy": "npm run build && node scripts/deploy-icloud.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "npm run typecheck && oxlint src",
		"lint:fix": "oxlint src --fix",
		"format": "oxfmt .",
		"format:check": "oxfmt . --check"
	},
	"dependencies": {
		"lucide-react": "^1.23.0",
		"obsidian": "^1.13.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"ts-fsrs": "^5.4.1"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	}
}
